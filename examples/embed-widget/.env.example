# ─────────────────────────────────────────────────────────────────────────────
# AAStar embed-widget configuration
# Copy to `.env.local` and fill in. All values are PUBLIC (shipped to the browser),
# so NEVER put a private key or any secret here. See README "Security".
# ─────────────────────────────────────────────────────────────────────────────

# AirAccount / KMS backend base URL (email + passkey register/login, gasless transfer).
# This is YAAAClient.apiURL. TODO: point this at a running AirAccount/KMS backend.
# (Local dev default shown; replace with your deployment.)
VITE_AIRACCOUNT_API_URL=http://localhost:3000/api/v1

# Comma-separated BLS seed node URLs used by YAAAClient for signer discovery.
# TODO: replace with real signer endpoints (optional for read-only / register-only flows).
VITE_BLS_SEED_NODES=https://signer1.aastar.io,https://signer2.aastar.io

# Target chain. Supported (have canonical AAStar addresses): "sepolia", "optimism",
# "optimismSepolia". Addresses auto-resolve from the chain id inside the SDK.
VITE_CHAIN=sepolia

# JSON-RPC URL for the chosen chain (balance reads, address prediction).
# TODO: use your own RPC provider; public endpoints are rate-limited.
VITE_RPC_URL=https://rpc.sepolia.org

# SuperPaymaster operator address that sponsors gas for this app's users.
# TODO: set to the operator you registered with SuperPaymaster.
VITE_SP_OPERATOR=0x0000000000000000000000000000000000000000
