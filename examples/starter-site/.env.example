# ─────────────────────────────────────────────────────────────────────────────
# AAStar starter-site configuration. Copy to `.env.local`.
# All values are PUBLIC (shipped to the browser). NEVER put a private key here.
# ─────────────────────────────────────────────────────────────────────────────

# AirAccount / KMS backend base URL (email + passkey). TODO: your deployment.
VITE_AIRACCOUNT_API_URL=http://localhost:3000/api/v1

# Comma-separated BLS seed node URLs. TODO: real signer endpoints.
VITE_BLS_SEED_NODES=https://signer1.aastar.io,https://signer2.aastar.io

# Target chain: "sepolia" | "optimism" | "optimismSepolia".
VITE_CHAIN=sepolia

# JSON-RPC URL for balance reads. TODO: your own RPC provider.
VITE_RPC_URL=https://rpc.sepolia.org

# SuperPaymaster operator that sponsors gas. TODO: your registered operator.
VITE_SP_OPERATOR=0x0000000000000000000000000000000000000000

# Registry contract address for the dashboard's on-chain credit-limit read.
# Optional: leave blank to show "n/a". TODO: set to the Registry on your chain.
VITE_REGISTRY_ADDRESS=
