{
  "name": "@aastar/email",
  "version": "0.20.7",
  "description": "Email utility for the AAStar SDK — Resend API wrapper for server-side and agent use",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "find src -name '*.js' -o -name '*.d.ts' -o -name '*.map' | xargs rm -f",
    "prebuild": "pnpm clean",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "vitest": "^2.0.0"
  },
  "private": true
}
