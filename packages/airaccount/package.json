{
  "name": "@aastar/airaccount",
  "version": "0.17.7",
  "description": "AirAccount SDK - ERC-4337 Account Abstraction with KMS WebAuthn, BLS Aggregate Signatures, and Tiered Signature Routing",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./core/bls": {
      "types": "./dist/core/bls/index.d.ts",
      "import": "./dist/core/bls/index.js",
      "require": "./dist/core/bls/index.cjs"
    },
    "./core/erc4337": {
      "types": "./dist/core/erc4337/index.d.ts",
      "import": "./dist/core/erc4337/index.js",
      "require": "./dist/core/erc4337/index.cjs"
    },
    "./auth/passkey": {
      "types": "./dist/auth/passkey/index.d.ts",
      "import": "./dist/auth/passkey/index.js",
      "require": "./dist/auth/passkey/index.cjs"
    },
    "./auth/hardware": {
      "types": "./dist/auth/hardware/index.d.ts",
      "import": "./dist/auth/hardware/index.js",
      "require": "./dist/auth/hardware/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "dist/server/index.d.ts"
      ],
      "core/bls": [
        "dist/core/bls/index.d.ts"
      ],
      "core/erc4337": [
        "dist/core/erc4337/index.d.ts"
      ],
      "auth/passkey": [
        "dist/auth/passkey/index.d.ts"
      ],
      "auth/hardware": [
        "dist/auth/hardware/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prebuild": "pnpm clean"
  },
  "keywords": [
    "aastar",
    "airaccount",
    "erc4337",
    "account-abstraction",
    "bls",
    "passkey",
    "webauthn",
    "kms",
    "ethereum",
    "web3"
  ],
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@simplewebauthn/browser": "^13.2.2",
    "axios": "^1.12.2"
  },
  "optionalDependencies": {
    "@ledgerhq/hw-app-eth": "^7.6.0",
    "@ledgerhq/hw-transport-webhid": "^6.33.0"
  },
  "devDependencies": {
    "ethers": "^6.11.1",
    "tsup": "^8.0.2",
    "typescript": "5.7.2"
  }
}
