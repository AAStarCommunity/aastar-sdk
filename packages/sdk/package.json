    "erc-4337",
    "account-abstraction",
    "gasless",
    "paymaster",
    "superpaymaster",
    "webauthn",
    "passkey",
    "bls",
    "viem",
    "optimism",
    "ethereum",
    "smart-account",
    "aastar",
    "mycelium"
  ],
  "homepage": "https://github.com/AAStarCommunity/aastar-sdk#readme",
