{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@aastar/airaccount/server": ["../airaccount/src/server/index.ts"],
      "@aastar/*": ["../*/src/index.ts"]
    }
  },
  "include": ["src", "src/abis/*.json"]
}
