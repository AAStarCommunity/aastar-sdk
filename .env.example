# Environment variables required for paper3_failover_simulation.mjs
# Copy this file to .env.sepolia and fill in your values.
#
# Usage:
#   source .env.sepolia && node packages/analytics/scripts/paper3_failover_simulation.mjs

# Private key of an EOA that owns the SimpleAccount used in the experiment.
# The SimpleAccount (ERC-4337 v0.7) must be deployed and hold >= 0.005 ETH for gas.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC URL (Alchemy, Infura, or any Sepolia endpoint)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optional: number of trials (default: 50)
# N_TRIALS=50
