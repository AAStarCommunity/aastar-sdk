# ======================================================================
# Paper3 v7.9 — Alchemy Controlled Baseline Environment
# ======================================================================
# Copy to .env.op-mainnet.controlled and fill in ALL values below.
# This file is loaded BEFORE .env.op-mainnet (which provides cast wallet + RPC config).
# NEVER commit .env.op-mainnet.controlled with real API keys.
# ======================================================================

# ----- Alchemy Gas Manager (required for Alchemy sponsorship) -----
#
# Step-by-step setup:
#   1. Visit https://dashboard.alchemy.com
#   2. Create or select an App on Optimism Mainnet (mainnet, not sepolia)
#   3. Under Gas Manager → Create Policy:
#        - Type:          Sponsorship
#        - Network:       Optimism Mainnet
#        - EntryPoint:    v0.7 (0x0000000071727De22E5E9d8BAf0edAc6f37da032)
#        - Allowlist:     Add your JASON_AA address (below)
#        - Per-UO cap:    $0.05  (plenty for USDC transfer on OP L2)
#        - Max count:     30     (n=22 + slack)
#        - Time window:   24 hours (optional)
#   4. Copy the Policy ID (UUID shown in policy detail page)
#   5. Paste below.
#
ALCHEMY_PAYMASTER_POLICY_ID=

# Alchemy OP Mainnet RPC (serves bundler + paymaster + gas manager on one URL).
# Reuse your existing key from .env.op-mainnet if you have one — MUST be mainnet not sepolia.
ALCHEMY_RPC_URL_OP=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Optional: Pin the Alchemy paymaster contract address (forward-compat).
# As of 2026 the canonical OP Mainnet EP v0.7 paymaster is the one below.
# The script will auto-detect from the sponsorship response if unset, but pinning
# here lets the reverse-extraction step work even before any successful run.
ALCHEMY_PAYMASTER_ADDR=0x2cc0c7981D846b9F2a16276556f6e8cb52BfB633


# ----- Controlled experiment account (required) -----
#
# The SimpleAccount (EP v0.7) deployed for Jason AA on OP Mainnet.
# Must match the account used in prior v7.8 experiments for strict comparability.
# See config.op-mainnet.json → simpleAccountFactory for the factory.
# Jason AA (reference from OP gas report):
JASON_AA=0xe8eaad6a4802300f33e53c40e65863cccda6898b

# ----- Controlled transfer parameters -----
#
# Destination address for the ERC-20 transfer (keep constant across all runs).
# Default: Anni's EOA (you can use any non-zero address; we don't actually care about the funds).
# CONTROLLED_RECIPIENT=0x08822612177e93a5B8dA59b45171638eb53D495a   # optional override; falls back to $ANNI_ADDRESS from .env.op-mainnet

# OP Mainnet native USDC (6 decimals):
CONTROLLED_USDC=0x0b2c639c533813f4aa9d7837caf62653d097ff85

# Transfer amount in token base units. 1000 = 0.001 USDC (cheap).
CONTROLLED_TRANSFER_AMOUNT=1000


# ----- Notes on what is NOT needed here -----
#
# The following are inherited from .env.op-mainnet (no need to duplicate):
#   DEPLOYER_ACCOUNT         (cast wallet name, e.g. optimism-deployer)
#   DEPLOYER_ADDRESS         (Jason EOA)
#   ANNI_ACCOUNT / ANNI_ADDRESS
#   OPT_MAINNET_RPC          (fallback RPC if ALCHEMY_RPC_URL_OP not set)
#   CHAIN_ID                 (fixed to 10 for OP mainnet)
#
# Entry point, factories, our paymasters: loaded from config.op-mainnet.json.
